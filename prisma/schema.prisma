generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobStatus {
  BOOKED
  ARRIVED
  IN_PROGRESS
  WAITING_PARTS
  WAITING_COLLECTION
  COMPLETED
  CANCELLED
}

enum JobLineItemType {
  LABOUR
  PART
  MISC
}

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Workshop {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  address              String?
  phone                String?
  email                String?
  nextJobNumber        Int          @default(1001)
  slotLength           Int          @default(60)
  workingDayStartMins  Int          @default(480)
  workingDayEndMins    Int          @default(1080)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  customers            Customer[]
  vehicles             Vehicle[]
  jobs                 Job[]
  jobLineItems         JobLineItem[]
  jobTypes             JobType[]
  memberships          Membership[]
  subscription         Subscription?
}

model Subscription {
  id                   String             @id @default(cuid())
  workshopId           String             @unique
  status               SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workshop             Workshop           @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Membership {
  id          String         @id @default(cuid())
  clerkUserId String         @unique
  workshopId  String
  role        MembershipRole @default(OWNER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workshop    Workshop       @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([clerkUserId])
  @@index([workshopId])
}

model Customer {
  id         String    @id @default(cuid())
  workshopId String
  name       String
  phone      String?
  email      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  workshop   Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]
  jobs       Job[]

  @@index([workshopId, name])
}

model Vehicle {
  id           String    @id @default(cuid())
  workshopId   String
  customerId   String
  registration String
  make         String?
  model        String?
  fuel         String?
  engine       String?
  engineSizeCc Int?
  year         Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workshop     Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs         Job[]

  @@unique([workshopId, registration])
  @@index([workshopId, customerId])
}

model JobType {
  id         String    @id @default(cuid())
  workshopId String
  name       String
  color      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  workshop   Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  jobs       Job[]

  @@unique([workshopId, name])
}

model Job {
  id             String     @id @default(cuid())
  workshopId     String
  jobNumber      Int
  customerId     String
  vehicleId      String
  jobTypeId      String
  status         JobStatus  @default(BOOKED)
  scheduledStart DateTime
  durationMins   Int
  notes          String?
  internalNotes  String?
  technicianNotes String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workshop       Workshop   @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  customer       Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle        Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  jobType        JobType    @relation(fields: [jobTypeId], references: [id], onDelete: Restrict)
  lineItems      JobLineItem[]

  @@index([workshopId, scheduledStart])
  @@index([workshopId, status])
  @@unique([workshopId, jobNumber])
}

model JobLineItem {
  id             String          @id @default(cuid())
  workshopId     String
  jobId          String
  description    String
  itemType       JobLineItemType @default(LABOUR)
  quantity       Decimal         @db.Decimal(10, 2)
  unitPrice      Decimal         @db.Decimal(10, 2)
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workshop       Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([workshopId, jobId])
  @@index([jobId, position])
}
